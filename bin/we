#!/usr/bin/env bash
# we — Legion CLI wrapper (downstream consumer).
#
# Pulls a pinned release of `we` from the 3dl-dev/legion GitHub releases and
# caches it in $HOME/.local/lib/legion-we/<version>/. The pinned version is
# read from .we-version (looked up from the script directory upward).
#
# Usage: we <args>           — run we at the pinned version (auto-installs)
#        we upgrade [tag]    — rewrite .we-version (default: latest) and install
#
# The legion repo is private, so downloads use `gh release download` for auth.
set -euo pipefail

REPO="3dl-dev/legion"
CACHE_ROOT="$HOME/.local/lib/legion-we"

OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)
case "$ARCH" in
  x86_64)        ARCH="amd64" ;;
  aarch64|arm64) ARCH="arm64" ;;
esac
ASSET="we-${OS}-${ARCH}.tar.gz"

_script_dir() {
  local script
  script="$(readlink -f "${BASH_SOURCE[0]}")"
  dirname "$script"
}

_version_file() {
  local dir
  dir="$(_script_dir)"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.we-version" ]; then
      echo "$dir/.we-version"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "ERROR: no .we-version found above $(_script_dir)" >&2
  return 1
}

_pinned_version() {
  local f
  f="$(_version_file)"
  tr -d '[:space:]' < "$f"
}

_install() {
  local version="$1"
  local dest_dir="$CACHE_ROOT/$version"
  local dest_bin="$dest_dir/we"

  if [ -x "$dest_bin" ]; then
    return 0
  fi

  if ! command -v gh >/dev/null 2>&1; then
    echo "ERROR: gh CLI required to download $REPO releases (private repo)." >&2
    exit 1
  fi

  echo "Installing we $version ($OS/$ARCH) -> $dest_bin" >&2
  mkdir -p "$dest_dir"
  local tmp
  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' RETURN

  gh release download "$version" --repo "$REPO" --dir "$tmp" \
    --pattern "$ASSET" --pattern "${ASSET}.sha256" >&2

  (cd "$tmp" && sha256sum -c "${ASSET}.sha256" >&2)
  tar xzf "$tmp/$ASSET" -C "$tmp"
  install -m 755 "$tmp/we" "$dest_bin"
  echo "Installed we $version" >&2
}

if [ "${1:-}" = "upgrade" ]; then
  target="${2:-}"
  if [ -z "$target" ]; then
    if ! command -v gh >/dev/null 2>&1; then
      echo "ERROR: gh CLI required to resolve latest tag." >&2
      exit 1
    fi
    target=$(gh release view --repo "$REPO" --json tagName -q .tagName)
  fi
  vf="$(_version_file)"
  echo "$target" > "$vf"
  echo "Pinned $vf -> $target" >&2
  _install "$target"
  exit 0
fi

VERSION="$(_pinned_version)"
_install "$VERSION"
exec "$CACHE_ROOT/$VERSION/we" "$@"
