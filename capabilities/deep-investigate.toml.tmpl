
name  = "deep-investigate"
match = ["task:deep-investigate"]
tools = [
  "check-baseline", "baseline-stats",
  "search-events", "search-findings",
  "read-config",
  "annotate-finding", "resolve-finding",
  "load-skill",
]
model = "{{MODEL}}"
# NOTE: NO escalate tools — deep workers emit verdicts only; they never hand off
# to stage-C or create new work items. Escalation decisions belong to
# investigate-merge after aggregation.

[[tool_defs]]
name = "check-baseline"
description = "Check baseline frequency and history for an actor/entity. Returns JSON with known_user, action_count, last_seen, and baseline stats."
input_schema = '{"type":"object","properties":{"entity":{"type":"string","description":"actor email or username"},"source":{"type":"string","description":"connector source (e.g. github)"}},"required":["entity"]}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "check-baseline", "--mode", "exam", "--fixture-dir", "exams/fixtures/{{RUN_ID}}"]

[[tool_defs]]
name = "baseline-stats"
description = "Return aggregate baseline statistics for an actor or source: total event volume, time-of-day distribution, weekly cadence. Useful for spotting anomalous volume or timing without examining individual events."
input_schema = '{"type":"object","properties":{"entity":{"type":"string","description":"actor email or username (optional — omit for source-level stats)"},"source":{"type":"string","description":"connector source (e.g. github, aws)"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "baseline-stats", "--mode", "exam", "--fixture-dir", "exams/fixtures/{{RUN_ID}}"]

[[tool_defs]]
name = "search-events"
description = "Search recent events by actor, type, or time range. Returns JSON array of matching events."
input_schema = '{"type":"object","properties":{"actor":{"type":"string","description":"actor filter"},"source":{"type":"string","description":"connector source"},"type":{"type":"string","description":"event_type filter"},"since":{"type":"string","description":"RFC3339 start time"},"until":{"type":"string","description":"RFC3339 end time"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "search-events", "--mode", "exam", "--fixture-dir", "exams/fixtures/{{RUN_ID}}"]

[[tool_defs]]
name = "search-findings"
description = "Search existing findings by actor, severity, or time range. Returns JSON array of related findings within the last 30 days."
input_schema = '{"type":"object","properties":{"actor":{"type":"string"},"source":{"type":"string"},"since":{"type":"string"},"until":{"type":"string"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "search-findings", "--mode", "exam", "--fixture-dir", "exams/fixtures/{{RUN_ID}}"]

[[tool_defs]]
name = "read-config"
description = "Read connector or detector configuration (read-only). Returns JSON with detector thresholds, connector scope, and enabled sources. Useful for understanding what data is available and what the detector was configured to flag."
input_schema = '{"type":"object","properties":{"detector":{"type":"string","description":"detector name (optional)"},"connector":{"type":"string","description":"connector name (optional)"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "read-config", "--mode", "exam", "--fixture-dir", "exams/fixtures/{{RUN_ID}}"]

[[tool_defs]]
name = "load-skill"
description = "Load a domain-specific skill module to gain specialized tools and context (e.g. AWS IAM analysis, cloud attack patterns). Returns {skill_id, new_tools, context}. Only load when baseline tools are insufficient."
input_schema = '{"type":"object","properties":{"skill_name":{"type":"string","description":"skill name from the skill catalog"},"source_hint":{"type":"string","description":"optional source hint (e.g. aws, github) to filter catalog entries"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "load-skill"]

# F1G-a: Finding-state (output tools — deep workers close their own work item)
[[tool_defs]]
name = "resolve-finding"
description = "Close a finding with a resolution action. Deep workers emit 'resolved' (benign confirmed) or 'escalated' (suspicious or uncertain). Emits work:output to engagement campfire for investigate-merge to read."
input_schema = '{"type":"object","required":["finding_id","action","reason"],"properties":{"finding_id":{"type":"string"},"action":{"type":"string","enum":["resolved","escalated"]},"reason":{"type":"string"},"confidence":{"type":"number","minimum":0,"maximum":1}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "resolve-finding"]

[[tool_defs]]
name = "annotate-finding"
description = "Add a structured annotation to a finding. Posts finding:annotation to engagement campfire. Tag consumed by F4B academy structural grading."
input_schema = '{"type":"object","required":["finding_id","note"],"properties":{"finding_id":{"type":"string"},"note":{"type":"string","maxLength":4096},"tags":{"type":"array","items":{"type":"string"}}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "annotate-finding"]

# task:investigate-merge capability seed — F1E: evidence-aggregation across 3 deep workers
