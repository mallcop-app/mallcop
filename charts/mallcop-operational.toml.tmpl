# Operational chart template (legion v0.4.0 — API spawn path + legion.tools).
# Task-pipeline only: triage → investigate → deep-investigate → investigate-merge → escalate → heal.
# No bakeoff/exam skills — use charts/exam-bakeoff.toml.tmpl for bakeoff runs.
# Usage:
#   sed 's/{{MODEL}}/claude-sonnet-4-5/g; s/{{RUN_ID}}/20260414/g; s|{{FORGE_API_URL}}|${FORGE_BASE_URL:-https://forge.3dl.dev}|g; s|{{FORGE_API_KEY}}|mallcop-sk-...|g; s|{{TOOL_BIN_DIR}}|/path/to/bin|g' \
#     charts/mallcop-operational.toml.tmpl > mallcop-operational.toml
#
# Confidence gate (F2A — asymmetric gate, mallcoppro-276 + mallcoppro-499):
#   The gate is configured via MALLCOP_CONFIDENCE_GATED_CLOSE_* env vars read
#   by cmd/mallcop-investigate-tools/tools_f1g_gate.go at tool invocation.
#   IMPORTANT: legion's apiToolEnv (3dl-dev/legion: internal/worker/worker.go
#   apiToolEnv) does NOT pass these env vars through to API-path tool
#   subprocesses — its passthrough list is hard-coded (ANTHROPIC_*, FORGE_*,
#   GRAPH_*, MALLCOP_RUN_ID). Setting [env] here, or exporting them in the
#   activate envelope, does NOT reach the gate. The binary defaults in
#   tools_f1g_gate.go's defaultGateConfig are the effective configuration for
#   worker-spawned invocations. Binary defaults:
#     - Enabled=true
#     - ScoreFloor=0.40         (task:investigate — multi-tool flow, ~4 tools typical)
#     - TriageScoreFloor=0.18   (task:triage    — 2-tool flow, score ~0.24 typical)
#   The gate fires on both task:investigate and task:triage resolved-actions.
#   On triage, the fan-out is a single force escalate-to-investigator handoff
#   (not the investigate-tier deep×3 + merge panel). If legion grows env-var
#   passthrough for the MALLCOP_CONFIDENCE_GATED_CLOSE_* prefix, the defaults
#   can be flipped back and policy can move into [env] here.

[identity]
name     = "mallcop-operational-{{RUN_ID}}"
type     = "worker"
key_file = ".run/operational-{{RUN_ID}}/identity.json"    # fresh per run

[[worksources]]
type     = "ready"
campfire = "operational-{{RUN_ID}}"
skills   = ["task:triage", "task:investigate", "task:deep-investigate", "task:investigate-merge", "task:escalate", "task:heal"]

[budget]
# legion-370 (v0.12.0): max_tokens_per_session was an in-memory monotonic counter
# that wedged the dispatcher silently on overflow (5,153,121/5,000,000 in 14 min
# on bakeoff-20260602-152510). Removed in favor of:
#   - per-mission rd CumulativeTokensUsed (persisted on the rd item)
#   - per-automaton L3 spend_rate (rolling window — set below if needed)
#   - per-worker CapabilityBudgetCap (per-capability token_budget)
# A bakeoff lane historically burns 5-15M tokens uncapped; leaving rate
# unset lets the run complete. Per-worker bounding comes from capability
# token_budget + tool_loop turn cap (20).
max_tokens_per_task    = 15000

[autonomy]
max_tasks_per_session  = 200

[curator]
disabled = true                      # non-Claude operational run — the Sonnet-tier curator 401s against Anthropic

[tools]
# Expose legion.tools v1 ops to API-path workers. Injected as native ToolDefs
# into the tool_loop at spawnAPI time (legion v0.4.0 legion-cbc).
enabled = ["fetch_work_output", "list_work_items", "get_session_transcript"]

  [tools.party_grants]
  # Cross-skill read grants (legion-96a). A caller with skill X can read outputs
  # produced by skills listed here. Without a grant, fetch_work_output /
  # get_session_transcript return {"error":"unauthorized"} as JSON.
  # F1B-H will fill in task:* → task:* grants as seeds are defined.
  "task:investigate-merge" = ["task:deep-investigate"]

[capabilities]
gate_policy    = "ungated"
tool_allowlist = [
  "check-baseline", "baseline-stats", "search-events", "search-findings",
  # heal query tool + investigate-extension tools
  "read-finding", "read-config", "load-skill",
  # F1G-a: finding-state
  "resolve-finding", "annotate-finding",
  # F1G-b: chain-handoff
  "escalate-to-investigator", "escalate-to-stage-c", "escalate-to-deep",
  "create-investigate-merge", "write-partial-transcript",
  # F1G-c: operator/escalation
  "list-actions", "remediate-action", "request-approval", "message-operator",
  # F1G-d: approve-action
  "approve-action",
  # F2B: engagement-campfire watcher (mallcoppro-753)
  "watch-engagement-campfire",
]

[lifecycle]
max_workers   = 16                   # mallcoppro-749: bumped 4→16 after phase-timing analysis on bk-20260518-151733 showed median queue wait 250-360s vs median worker run 9s. Pool shared with mallcop-deploy ops items via engagement-campfire watcher; the bakeoff effectively got ~2 workers at 4. 16 gives headroom even with deploy-ops contention. Re-evaluate if Forge/Bedrock 429s appear.
time_limit    = "90m"
poll_interval = "10s"

[inference]
forge_api_url = "{{FORGE_API_URL}}"
api_key       = "{{FORGE_API_KEY}}"
[inference.local_model_mapping]
local = "qwen3-coder-30b"

[agents]
dir = "agents"
# Skills derive to the "b" half of "a:b" by default (task:investigate → investigate,
# task:heal → heal, etc.). Only override when the spec name differs from that derivation.

[campfire]
transport_dir = ".run/operational-{{RUN_ID}}/campfires"

[sandbox]
extra_ro = [
  "agents/",
]
