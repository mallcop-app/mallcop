
name  = "escalate"
match = ["task:escalate"]
tools = [
  "list-actions", "remediate-action", "request-approval",
  "message-operator", "annotate-finding", "resolve-finding",
]
model     = "{{MODEL}}"

  # F1G-c: Operator/escalation tools
[[tool_defs]]
name = "list-actions"
description = "List available remediation actions for a detector from the registry. Returns array of {action_name, action_class, description}. action_class: auto-safe (no approval needed), needs-approval (requires request-approval gate), informational, ambiguous."
input_schema = '{"type":"object","required":["detector"],"properties":{"detector":{"type":"string","description":"detector name to filter actions"},"action_class_filter":{"type":"string","description":"optional filter: auto-safe|needs-approval|informational|ambiguous"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "list-actions"]

[[tool_defs]]
name = "remediate-action"
description = "Record a remediation action for a finding (v1 stub — records intent, does not execute). Posts remediation:action-record to operator campfire with action_name+finding_id+timestamp. Returns receipt_id. Use for auto-safe actions only; use request-approval for needs-approval actions."
input_schema = '{"type":"object","required":["finding_id","action_name"],"properties":{"finding_id":{"type":"string"},"action_name":{"type":"string","description":"action name from list-actions"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "remediate-action"]

[[tool_defs]]
name = "request-approval"
description = "Post an approval-request gate (future message) to the operator campfire. Returns gate_id. The gate is fulfilled by the mallcop operator via approve-action. Use for needs-approval actions. The worker should await gate fulfillment before proceeding."
input_schema = '{"type":"object","required":["finding_id","action_name","justification"],"properties":{"finding_id":{"type":"string"},"action_name":{"type":"string"},"justification":{"type":"string","description":"why this action is necessary"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "request-approval"]

[[tool_defs]]
name = "message-operator"
description = "Send a message to the operator campfire. category: informational (findings update), instruction (operator directed action), action-receipt (confirming action taken), open-question (awaiting operator input). Returns message_id."
input_schema = '{"type":"object","required":["finding_id","message"],"properties":{"finding_id":{"type":"string"},"message":{"type":"string","maxLength":8192},"category":{"type":"string","enum":["informational","instruction","action-receipt","open-question"]}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "message-operator"]

[[tool_defs]]
name = "resolve-finding"
description = "Close a finding with a resolution action. Emits work:output to engagement campfire."
input_schema = '{"type":"object","required":["finding_id","action","reason"],"properties":{"finding_id":{"type":"string"},"action":{"type":"string","enum":["resolved","escalated","remediated"]},"reason":{"type":"string"},"confidence":{"type":"number","minimum":1,"maximum":5}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "resolve-finding"]

[[tool_defs]]
name = "annotate-finding"
description = "Add finding:annotation tagged note to engagement campfire."
input_schema = '{"type":"object","required":["finding_id","note"],"properties":{"finding_id":{"type":"string"},"note":{"type":"string","maxLength":4096},"tags":{"type":"array","items":{"type":"string"}}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "annotate-finding"]

# F1G-d: approve-action (mallcop-side, fulfills request-approval gates)
# NOTE: this tool is included in the escalate seed so the mallcop automaton
# can fulfill gates. The mallcop POST.md (F3B) is responsible for ensuring
# this is only called after explicit human operator approval.
[[tool_defs]]
name = "approve-action"
description = "Fulfill an approval gate posted by request-approval. OPERATOR-TIER ONLY. Must only be called after explicit human operator approval — mallcop POST.md (F3B) enforces this. operator_reason is REQUIRED (captures human voice in audit trail). No auto-approve mode exists."
input_schema = '{"type":"object","required":["gate_id","verdict","operator_reason"],"properties":{"gate_id":{"type":"string","description":"gate ID from request-approval response"},"verdict":{"type":"string","enum":["approved","denied"],"description":"explicit verdict — no default, no auto-approve"},"operator_reason":{"type":"string","description":"REQUIRED: free-text capturing the human operator reasoning for the audit trail"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "approve-action"]

# task:heal capability seed — F1H: parser-fix actor (log_format_drift only)
