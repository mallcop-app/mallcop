# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace file
go.work
go.work.sum

# Dependency directories
vendor/

# Build output
/dist/
/bin/**
!/bin/we
!/bin/we_test.sh

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env files
.env
.env.*
!.env.example

# Agent identity files — per-machine, managed by `cf init --name <type>`.
# Symlinked into agents/<type>/identity.json at runtime; see test/budget helpers.
agents/*/identity.json

# Compiled binaries built at the repo root by `go build` / `go test -c`.
# These should never be committed — the wrapper at bin/we is the only tracked
# binary path, all other binaries are produced into bin/ or t.TempDir().
/baseline
/detector-*
/mallcop
/mallcop-academy
/mallcop-finding-context
/mallcop-investigate-tools

# Runtime state — created by `cf` / `we` / `mallcop-academy` smoke runs.
# These are per-run scratch; never commit them.
/.cf/
/.run/

# Smoke / dev scripts that may contain credentials. Add committed scripts
# explicitly (allowlist) once they are scrubbed of secrets.
/run-smoke.sh
/run-smoke-*.sh
