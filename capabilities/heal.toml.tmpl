
name      = "heal"
match     = ["task:heal"]
tools     = [
  "read-finding", "annotate-finding", "resolve-finding",
  # mallcoppro-db3 Fix 3: lookup pre-seeded operator-decision rules; citing a
  # returned rule_id in resolve-finding satisfies the F2A citation requirement.
  "lookup-rules",
]
model     = "{{MODEL}}"

[[tool_defs]]
name = "read-finding"
description = "Read the full finding record by finding_id from the fixture. Returns the finding JSON or {\"error\":\"not_found\",\"finding_id\":\"...\"} if not present."
input_schema = '{"type":"object","required":["finding_id"],"properties":{"finding_id":{"type":"string","description":"finding ID to look up"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "read-finding", "--mode", "exam", "--fixture-dir", "exams/fixtures/{{RUN_ID}}"]

[[tool_defs]]
name = "annotate-finding"
description = "Add finding:annotation tagged note to engagement campfire. Use to store the parser.yaml patch JSON as annotation text."
input_schema = '{"type":"object","required":["finding_id","note"],"properties":{"finding_id":{"type":"string"},"note":{"type":"string","maxLength":4096},"tags":{"type":"array","items":{"type":"string"}}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "annotate-finding"]

[[tool_defs]]
name = "resolve-finding"
description = "Close a finding with a resolution action. Use action=\"resolved\" after annotating with the parser patch proposal. Optional rule_id cites a pre-seeded operator-decision rule (from lookup-rules) — a valid rule_id satisfies the F2A citation requirement without requiring a retrieved event ID in the reason field."
input_schema = '{"type":"object","required":["finding_id","action","reason"],"properties":{"finding_id":{"type":"string"},"action":{"type":"string","enum":["resolved","escalated","remediated"]},"reason":{"type":"string"},"confidence":{"type":"number","minimum":1,"maximum":5},"rule_id":{"type":"string","description":"optional operator-decision rule_id returned by lookup-rules; when valid, satisfies the F2A citation requirement"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "resolve-finding"]

# mallcoppro-db3 Fix 3: Operator-decision rule lookup
[[tool_defs]]
name = "lookup-rules"
description = "Match the current finding against pre-seeded operator decisions and return matching rules. Pass the finding_id and finding_family (the detector family, e.g. \"unusual-timing\", \"new-actor\", \"volume-anomaly\") along with any observable flags (maintenance_window, scheduled, resolution_event, location_change, automation_provenance, deploy_release, sensitive_bulk_read, hr_provisioning, scenario_pattern, actor_role) — returns 0 or more matching rules with id, applies_to, and operator_directive. When a returned rule matches the situation, pass its id to resolve-finding as rule_id; this satisfies the F2A citation requirement without requiring you to embed retrieved event IDs in the reason field."
input_schema = '{"type":"object","required":["finding_id","finding_family"],"properties":{"finding_id":{"type":"string"},"finding_family":{"type":"string","description":"detector family or finding.detector value"},"maintenance_window":{"type":"string","description":"\"true\" when the finding falls inside a declared maintenance window"},"scheduled":{"type":"string","description":"\"true\" when the activity is on a declared schedule (cron/batch)"},"resolution_event":{"type":"string","description":"name of the event_type that resolves the finding (e.g. login_success)"},"location_change":{"type":"string","description":"\"true\" when actor source location/IP changed legitimately"},"automation_provenance":{"type":"string","description":"automation source when known (e.g. terraform, github-actions)"},"deploy_release":{"type":"string","description":"\"true\" when activity is part of a deploy/release window"},"sensitive_bulk_read":{"type":"string","description":"\"true\" when the activity is a sensitive bulk read"},"hr_provisioning":{"type":"string","description":"\"true\" when the activity ties to an HR-system provisioning event"},"scenario_pattern":{"type":"string","description":"named scenario pattern (e.g. maintenance-window, scheduled-batch, fat-finger)"},"actor_role":{"type":"string","description":"actor role classifier (e.g. automation, human, ci-bot)"}}}'
binary = "{{TOOL_BIN_DIR}}/mallcop-investigate-tools"
binary_args = ["--tool", "lookup-rules"]
